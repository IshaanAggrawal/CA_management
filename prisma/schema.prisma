generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum UserRole {
  ADMIN
  STAFF
}

enum ClientStatus {
  ACTIVE
  PENDING_KYC
  INACTIVE
}

enum ClientEntityType {
  CORPORATE
  INDIVIDUAL
  LLP
  OTHER
}

enum AssignmentStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
}

enum AssignmentPriority {
  LOW
  MEDIUM
  HIGH
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
}

enum DocumentDirection {
  INWARD
  OUTWARD
  INTERNAL
}

model User {
  id         String        @id // Maps to Clerk User ID
  email      String        @unique
  name       String
  jobTitle   String?       // E.g., "Senior Partner", "Manager", "Associate"
  role       UserRole      @default(STAFF)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @default(now()) @updatedAt
  
  assignments Assignment[]
  activityLogs ActivityLog[]
  documents   Document[]
  supportTickets SupportTicket[]
}

model Client {
  id         String        @id @default(cuid())
  name       String
  entityType ClientEntityType @default(OTHER)
  partnerName String?
  contactPerson String?
  city       String?
  pan        String?
  gstin      String?
  email      String?
  phone      String?
  status     ClientStatus  @default(ACTIVE)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @default(now()) @updatedAt

  assignments Assignment[] 
  invoices    Invoice[]
  documents   Document[]
  digitalSignatures DigitalSignature[]
  udins       Udin[]
}

model Assignment {
  id          String             @id @default(cuid())
  title       String
  description String?
  status      AssignmentStatus    @default(TODO)
  priority    AssignmentPriority  @default(MEDIUM)
  deadline    DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  
  clientId    String
  client      Client             @relation(fields: [clientId], references: [id])
  userId      String?
  user        User?              @relation(fields: [userId], references: [id])
  udins       Udin[]

  @@index([clientId])
  @@index([userId])
  @@index([status])
  @@index([deadline])
}

model Invoice {
  id             String        @id @default(cuid())
  amount         Decimal       @db.Decimal(12, 2)
  status         InvoiceStatus @default(PENDING)
  dueDate        DateTime
  paymentLinkId  String?
  paymentLinkUrl String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([status])
  @@index([dueDate])
}

model ActivityLog {
  id          String     @id @default(cuid())
  action      String     // e.g. "CREATED", "UPDATED", "DELETED"
  entityType  String     // e.g. "ASSIGNMENT", "CLIENT"
  entityId    String
  details     String?    // e.g. "Status changed from TODO to IN_PROGRESS"
  createdAt   DateTime   @default(now())
  
  userId      String?
  user        User?      @relation(fields: [userId], references: [id])
}

model Document {
  id          String            @id @default(cuid())
  name        String
  url         String
  size        Int?              // in bytes
  direction   DocumentDirection @default(INTERNAL)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  
  clientId    String
  client      Client            @relation(fields: [clientId], references: [id])
  userId      String?
  user        User?             @relation(fields: [userId], references: [id])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

model SupportTicket {
  id          String         @id @default(cuid())
  subject     String
  description String
  category    String
  priority    TicketPriority @default(LOW)
  status      TicketStatus   @default(OPEN)
  attachmentUrl String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  userId      String?
  user        User?          @relation(fields: [userId], references: [id])
}

enum DscStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

model DigitalSignature {
  id           String    @id @default(cuid())
  providerName String
  password     String?
  issueDate    DateTime?
  expiryDate   DateTime
  status       DscStatus @default(ACTIVE)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  clientId     String
  client       Client    @relation(fields: [clientId], references: [id])
}

model Udin {
  id           String    @id @default(cuid())
  udinNumber   String    @unique
  documentType String
  generatedAt  DateTime
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  clientId     String
  client       Client    @relation(fields: [clientId], references: [id])
  assignmentId String?
  assignment   Assignment? @relation(fields: [assignmentId], references: [id])
}
